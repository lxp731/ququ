{
  "name": "ququ",
  "version": "1.1.8",
  "description": "蛐蛐 - 基于FunASR和AI的中文语音转文字应用",
  "main": "main.js",
  "private": true,
  "repository": "https://github.com/lxp731/ququ",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k --restart-tries 3 \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:main": "cross-env NODE_ENV=development ELECTRON_RUN_AS_NODE= electron . --no-sandbox --dev",
    "dev:renderer": "vite",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview"
  },
  "keywords": [
    "dictation",
    "speech-to-text",
    "funasr",
    "ai",
    "chinese",
    "electron"
  ],
  "author": {
    "name": "yan5xu",
    "email": "lueco.x@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.10",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.0.0",
    "electron": "36.5.0",
    "electron-builder": "^24.6.4",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.10",
    "vite": "^6.3.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "axios": "^1.6.0",
    "better-sqlite3": "11.10.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.518.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  },
  "build": {
    "appId": "com.ququ.app",
    "productName": "蛐蛐",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "node_modules/**/*",
      "dist/**/*",
      "src/helpers/**/*",
      "assets/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/electron/**/*"
    ],
    "asarUnpack": [
      "node_modules/**/*better-sqlite3*/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Office",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ququ-v${version}.${ext}",
      "maintainer": "yan5xu <lueco.x@gmail.com>",
      "synopsis": "蛐蛐 - 中文语音输入工具",
      "description": "开源免费的 Wispr Flow 替代方案，基于 FunASR 本地语音识别和可配置 AI 模型的语音转文字桌面应用。"
    },
    "deb": {
      "depends": [
        "libgtk-3-0 (>= 3.22)",
        "libnss3 (>= 2:3.35)",
        "libasound2 (>= 1.0.16)",
        "libx11-6",
        "libxcomposite1",
        "libxdamage1",
        "libxext6",
        "libxfixes3",
        "libxrandr2",
        "libgbm1",
        "libpango-1.0-0",
        "libcairo2",
        "libdrm2"
      ]
    },
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "ququ-v${version}.exe"
    }
  }
}
